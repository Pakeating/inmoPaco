---
import Layout from "../layouts/Layout.astro";
import AuctionSearch from "../components/AuctionSearch.astro";
import AuctionDetailContent from "../components/AuctionDetailContent.astro";
---

<Layout title="Detalles de Subasta - InmoPaco">
	<main class="container">
		<header class="page-header">
			<a href="/auctionsList" class="back-link">← Volver al Listado</a>
			<h1>Detalles de la Propiedad</h1>
		</header>

    <AuctionSearch />

    <AuctionDetailContent />
	</main>
</Layout>

<style>
	main.container {
		padding-top: 4rem;
		padding-bottom: 6rem;
		max-width: 1400px;
	}
	.page-header {
		margin-bottom: 2rem;
	}
	.back-link {
		display: inline-block;
		color: var(--color-text-muted);
		font-weight: 500;
    transition: color 0.2s;
	}
  .back-link:hover {
    color: var(--color-primary);
  }
</style>
