---
/**
 * Lista de subastas
 * Recibe el evento de búsqueda y renderiza las tarjetas de subasta.
 */
---

<div id="auction-results-wrapper">
  <div id="auction-results-container" class="auction-list">
    <!-- cards -->
    <div class="loading-state">Cargando subastas...</div>
  </div>

  <div id="no-results-view" class="no-results hidden">
    <p>No se encontraron subastas que coincidan con tus criterios.</p>
    <a href="/auctionsFilter" class="btn-accent">Volver al Buscador</a>
  </div>
</div>

<!-- Plantilla para card de subasta -->
<template id="auction-card-template">
  <div class="card auction-card">
    <div class="card-header">
      <span class="property-type"></span>
      <div class="status-badge" data-status=""></div>
    </div>
    <div class="auction-content">
      <h3 class="property-address"></h3>
      <p class="location"><span class="icon">📍</span> <span class="location-text"></span></p>
      
      <div class="auction-details">
        <div class="detail">
          <span class="label">Valor Subasta</span>
          <span class="value auction-value"></span>
        </div>
        <div class="detail">
          <span class="label">Depósito (5%)</span>
          <span class="value deposit-amount"></span>
        </div>
      </div>
      
      <a href="" class="btn-primary block detail-link">Ver Detalles</a>
    </div>
  </div>
</template>

<script>
  const container = document.getElementById('auction-results-container');
  const noResultsView = document.getElementById('no-results-view');
  // @ts-ignore
  const template = document.getElementById('auction-card-template');

  // Escuchar el evento cuando se obtienen nuevas subastas
  document.addEventListener('auctions:fetched', (event) => {
    // @ts-ignore
    const { results } = event.detail;
    
    // Limpiar resultados anteriores o estado de carga
    container.innerHTML = '';

    if (results.length === 0) {
      container.classList.add('hidden');
      noResultsView.classList.remove('hidden');
      return;
    }

    container.classList.remove('hidden');
    noResultsView.classList.add('hidden');

    results.forEach(auction => {
      // @ts-ignore
      const templateContent = template.content;
      const clone = templateContent.cloneNode(true);
      
      // Rellenar datos en el clon de la plantilla
      const badge = clone.querySelector('.status-badge');
      badge.textContent = auction.status;
      badge.dataset.status = auction.status;
      
      clone.querySelector('.property-type').textContent = auction.type;
      clone.querySelector('.property-address').textContent = auction.propertyAddress;
      clone.querySelector('.location-text').textContent = `${auction.city}, ${auction.province}`;
      
      clone.querySelector('.auction-value').textContent = auction.auctionValue;
      clone.querySelector('.deposit-amount').textContent = auction.depositAmount;
      
      clone.querySelector('.detail-link').href = `/auctionDetails?auctionIds=${auction.auctionId}`;
      
      container.appendChild(clone);
    });
  });
</script>

<style>
	.auction-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2.5rem;
	}
	.auction-card {
		padding: 0;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		position: relative;
    height: 100%;
    border-top: 4px solid var(--color-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
	}
  .auction-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .card-header {
    padding: 1.5rem 1.5rem 0.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
	.status-badge {
    position: static;
		padding: 0.25rem 0.75rem;
		border-radius: 2rem;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.status-badge[data-status="En curso"] {
		background-color: #22c55e;
		color: white;
	}
	.status-badge[data-status="Próximamente"] {
		background-color: #f59e0b;
		color: white;
	}
	.status-badge[data-status="Finalizada"] {
		background-color: #ef4444;
		color: white;
	}
	.property-type {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--color-accent);
		text-transform: uppercase;
	}
	.auction-content {
		padding: 0 1.5rem 1.5rem 1.5rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}
	h3 {
		margin-bottom: 0.5rem;
		font-size: 1.25rem;
	}
	.location {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
	}
	.auction-details {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-bottom: 1.5rem;
		padding: 1rem 0;
		border-top: 1px solid var(--border-color);
		border-bottom: 1px solid var(--border-color);
	}
	.detail {
		display: flex;
		flex-direction: column;
	}
	.label {
		font-size: 0.75rem;
		text-transform: uppercase;
		color: var(--color-text-muted);
		letter-spacing: 0.05em;
		margin-bottom: 0.25rem;
	}
	.value {
		font-weight: 700;
		color: var(--color-primary);
	}
	.block {
		display: block;
		text-align: center;
		width: 100%;
	}
	.no-results {
		text-align: center;
		padding: 4rem 2rem;
		background: var(--color-bg-card);
		border-radius: 1rem;
		border: 1px dashed var(--border-color);
		margin-top: 2rem;
	}
	.no-results p {
		font-size: 1.25rem;
		color: var(--color-text-muted);
		margin-bottom: 2rem;
	}
	.hidden {
		display: none;
	}
  .loading-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .page-info .total {
    color: var(--color-text-muted);
  }

  .btn-pagination .icon {
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .btn-pagination:hover:not(:disabled) .icon {
    transform: scale(1.2);
  }
</style>
